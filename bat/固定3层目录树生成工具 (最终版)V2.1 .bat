@echo off
setlocal

:: =================================================================
:: 脚本名称: 固定3层目录树生成工具 (最终版)V2.1 2025-9-22
:: =================================================================

echo 【名称】固定3层目录树生成工具 (最终版)V2.0 2025-9-22
echo 【作者】pixelpulse
echo 【说明】用于替代没有安装Git bash的电脑使用，模拟tree -d -N -L 3 命令，常用于多硬盘目录查看和管理
echo 【测试环境】Windows11 24H2
echo 【使用方法】直接将该脚本移动到你要打印的文件夹下，双击运行！O(∩_∩)O

:: 1. 定义临时文件的路径和名称。
set "TMP_FILE=%~dp0\~tree_output_%RANDOM%.tmp"

:: 2. 执行核心的目录扫描逻辑。
(
    echo .
    cd /d "%~dp0"
    for /d %%d in (*) do (
        echo +---%%~nxd
        for /d %%s in ("%%~fd\*") do (
            echo ^|   +---%%~nxs
            for /d %%t in ("%%~fs\*") do (
                echo ^|   ^|   +---%%~nxt
            )
        )
    )
) >"%TMP_FILE%" 2>&1

:: 3. 过滤并显示结果。
findstr /v "系统找不到指定的驱动器。" "%TMP_FILE%"

:: 4. 清理工作：执行临时文件清理操作
echo.
echo 正在清理临时文件...

:: 强制切换到主脚本所在的目录
cd /d "%~dp0"

:: 执行我们已在单元测试中验证成功的、最直接的删除命令
del /F /Q "~tree_output_*.tmp"
echo 清理完毕，请按查看目录树输出结果，如需退出请按任意键

endlocal
echo.
pause